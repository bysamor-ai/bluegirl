# ===== Supabase（公開金鑰，配合 RLS 使用，可暴露於客戶端）=====
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===== fal.ai（秘密，只限伺服器使用，切勿以 NEXT_PUBLIC_ 開頭）=====
FAL_KEY=your-fal-api-key

# 可選：覆寫圖片生成模型（預設 fal-ai/gpt-image-1/text-to-image）
# FAL_IMAGE_MODEL=fal-ai/gpt-image-1/text-to-image
